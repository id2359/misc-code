#!/usr/bin/env bash
set -euo pipefail

input_file=${1:-/dev/stdin}
export TS_INPUT_FILE="$input_file"
export TS_URI="${TS_URI:-druby://127.0.0.1:7640}"
export TS_TIMEOUT="${TS_TIMEOUT:-5}"

ruby <<'RUBY'
require 'drb/drb'
require 'rinda/tuplespace'
require 'socket'

uri = ENV.fetch('TS_URI')
timeout = Float(ENV.fetch('TS_TIMEOUT', '5'))
input_file = ENV.fetch('TS_INPUT_FILE')

def local_ip
  Socket.ip_address_list
    .select(&:ipv4?)
    .reject(&:ipv4_loopback?)
    .map(&:ip_address)
    .find { |addr| addr && !addr.empty? } || '127.0.0.1'
end

def parse_line(line, fallback_ip)
  text = line.strip
  return nil if text.empty? || text.start_with?('#')

  if text.start_with?('[:console,')
    inner = text.sub(/^\[:console,\s*/, '').sub(/\]\s*$/, '')
    parts = inner.scan(/"(?:\\.|[^"])*"|nil|[^,]+/).map(&:strip)
    raise "invalid tuple format: #{line.rstrip}" unless parts.length == 3

    key = parts[0].sub(/^"/, '').sub(/"$/, '').gsub('\\"', '"').gsub('\\\\', '\\')
    value = parts[1] == 'nil' ? nil : parts[1].sub(/^"/, '').sub(/"$/, '').gsub('\\"', '"').gsub('\\\\', '\\')
    ip = parts[2] == 'nil' ? fallback_ip : parts[2].sub(/^"/, '').sub(/"$/, '').gsub('\\"', '"').gsub('\\\\', '\\')
    return [key, value, ip]
  end

  if text.include?("\t")
    parts = text.split("\t", 3)
  else
    parts = text.split(/\s+/, 3)
  end

  raise "expected 'key value [ip]' or tsdump tuple: #{line.rstrip}" if parts.length < 2

  key = parts[0]
  value = parts[1]
  ip = parts[2] && !parts[2].empty? ? parts[2] : fallback_ip
  [key, value, ip]
end

fallback_ip = local_ip
DRb.start_service
ts = Rinda::TupleSpaceProxy.new(DRbObject.new_with_uri(uri))

File.foreach(input_file) do |line|
  tuple = parse_line(line, fallback_ip)
  next unless tuple
  key, value, ip = tuple
  ts.write([:console, key, value, ip], timeout)
end
RUBY
